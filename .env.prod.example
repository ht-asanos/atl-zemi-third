# === Supabase（本番） ===
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=<prod-anon-key>
SUPABASE_JWT_SECRET=<prod-jwt-secret>
SUPABASE_SERVICE_ROLE_KEY=<prod-service-role-key>

# === Backend ===
CORS_ORIGINS=https://<frontend-domain>
RAKUTEN_APP_ID=<prod-rakuten-app-id>
RAKUTEN_ACCESS_KEY=<prod-rakuten-access-key>
OPENAI_API_KEY=<prod-openai-key>
GOOGLE_API_KEY=<prod-google-key>
YOUTUBE_API_KEY=<prod-youtube-key>
YOUTUBE_RECIPE_CHANNELS=@Kurashiru,@ryuji825,@sanpiryoron
ADMIN_USER_IDS=

# === Frontend（ビルド時 — 必ず本番 URL を設定すること） ===
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<prod-anon-key>
NEXT_PUBLIC_API_URL=https://<backend-cloud-run-url>
